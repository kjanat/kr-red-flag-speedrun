{
	"name": "kr-red-flag-speedrun",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"bd": "bun run build",
		"build": "vite build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"dev": "vite dev",
		"fmt": "dprint fmt",
		"prepare": "svelte-kit sync || echo ''",
		"preview": "vite preview",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^25.3.5",
		"dprint": "^0.52.0",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vite-robots-txt": "^1.0.0",
		"vite-svg-to-ico": "^2.0.1",
		"vitest": "^4.0.18"
	},
	"packageManager": "bun@1.3.10"
}
